# Local model caches / downloaded weights
model-cache/
**/model-cache/
*.gguf

# Env files (HF tokens, RunPod API keys, etc.)
.env
*.env
!.env.example
!*.env.example
# Baked AMI boot config (no secrets; must be tracked so CI/Packer get it)
!aws/boot/prefer-boot.env

# Local corporate CA material for Netskope Docker builds
docker/certs/*.crt
docker/certs/*.pem

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# Node app build/dependency output
node_modules/
**/node_modules/
dist/
**/dist/

# Reproducible benchmark outputs are local by default. Deliberately scrubbed,
# reviewed baselines live in benchmark/baselines/ and remain tracked.
benchmark/artifacts/
__pycache__/
*.py[cod]
