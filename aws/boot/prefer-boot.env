# PreFer EC2 boot configuration.
#
# Baked into the AMI with defaults; per-deployment values (notably
# S3_BUCKET_NAME) are appended by the IaC/user-data on first boot, e.g.:
#   echo "S3_BUCKET_NAME=my-prefer-models" >> /opt/prefer/prefer-boot.env
#
# Read by systemd (EnvironmentFile=) every boot, and sourceable for debugging:
#   set -a; . /opt/prefer/prefer-boot.env; set +a

# Container image + pinned tag. A fresh `docker pull` runs on every instance
# start, so a new container build is picked up without rebuilding the AMI.
# `provision.sh` rewrites this line at AMI build time from the Packer var.
PREFER_IMAGE=ghcr.io/cvalusek/prefer:latest

# Instance-store NVMe mount point and the models subdir under it. Defaults to
# the DLAMI's own mount (/opt/dlami/nvme), managed by the dlami-nvme service.
NVME_MOUNT=/opt/dlami/nvme
MODELS_SUBDIR=models

# Host port mapped to the container's 8080.
LLM_PORT=8080

# S3 model cache bucket. Enables the sync-down/up path in the container's
# download-models.sh. Blank = disabled (Hugging Face only). Set per deployment.
S3_BUCKET_NAME=

# Limit which models are pre-staged on boot (comma-separated keys). Blank = the
# container's default (all of them). Set to one small model for a cheap first
# end-to-end test, e.g. PRESTAGE_MODELS=gemma-4-e2b
# Keys: gemma-4-26b-a4b, gemma-4-e2b, gemma-4-e4b, qwen-3.6-35b-a3b, qwen-3.6-27b, glm-4.7-flash
PRESTAGE_MODELS=
