{
  "schema_version": "prefer.eval-corpus.v1",
  "eval_version": "1.0.0",
  "data_class": "synthetic_non_private",
  "cases": [
    {
      "id": "aurora-facts-v1",
      "kind": "extraction",
      "source": "Synthetic drill note: Project Aurora has a review on 2026-08-14. Mira Chen owns the review. The required action is 'submit the risk register' and its due date is 2026-08-12. Launch remains paused until the review is complete.",
      "instruction": "Extract every requested field exactly from the note. Do not calculate, repair, or invent a date.",
      "output_schema": {
        "type": "object",
        "required": ["project", "review_date", "owner", "required_action", "due_date", "launch_state"],
        "properties": {
          "project": {"type": "string", "minLength": 1},
          "review_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
          "owner": {"type": "string", "minLength": 1},
          "required_action": {"type": "string", "minLength": 1},
          "due_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
          "launch_state": {"type": "string", "enum": ["paused"]}
        },
        "additionalProperties": false
      },
      "semantic_rules": [
        {"kind": "exact", "path": "/project", "value": "Project Aurora"},
        {"kind": "valid_date", "path": "/review_date"},
        {"kind": "exact", "path": "/review_date", "value": "2026-08-14"},
        {"kind": "exact", "path": "/owner", "value": "Mira Chen"},
        {"kind": "non_empty", "path": "/required_action"},
        {"kind": "exact", "path": "/required_action", "value": "submit the risk register"},
        {"kind": "valid_date", "path": "/due_date"},
        {"kind": "exact", "path": "/due_date", "value": "2026-08-12"},
        {"kind": "exact", "path": "/launch_state", "value": "paused"}
      ]
    },
    {
      "id": "cedar-plan-v1",
      "kind": "synthesis",
      "source": "Synthetic planning brief for Project Cedar. The plan must contain all three required steps: (1) Imani Rao validates the backup by 2026-09-03, with a restore log as evidence. (2) Theo Park runs the failover drill by 2026-09-05, with a drill transcript as evidence. (3) Imani Rao signs the release checklist by 2026-09-06, with the signed checklist as evidence. The release freeze begins on 2026-09-07.",
      "instruction": "Create a concise execution plan containing every required step, owner, due date, and evidence item. Do not add steps or dates.",
      "output_schema": {
        "type": "object",
        "required": ["plan_title", "steps", "release_freeze_date"],
        "properties": {
          "plan_title": {"type": "string", "minLength": 1},
          "steps": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "object",
              "required": ["sequence", "action", "owner", "due_date", "evidence"],
              "properties": {
                "sequence": {"type": "integer", "minimum": 1, "maximum": 3},
                "action": {"type": "string", "minLength": 1},
                "owner": {"type": "string", "minLength": 1},
                "due_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
                "evidence": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          },
          "release_freeze_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"}
        },
        "additionalProperties": false
      },
      "semantic_rules": [
        {"kind": "non_empty", "path": "/plan_title"},
        {"kind": "array_min_items", "path": "/steps", "value": 3},
        {"kind": "contains_object", "path": "/steps", "match": {"sequence": 1, "owner": "Imani Rao", "due_date": "2026-09-03"}, "contains": {"action": ["backup"], "evidence": ["restore", "log"]}},
        {"kind": "contains_object", "path": "/steps", "match": {"sequence": 2, "owner": "Theo Park", "due_date": "2026-09-05"}, "contains": {"action": ["failover", "drill"], "evidence": ["drill", "transcript"]}},
        {"kind": "contains_object", "path": "/steps", "match": {"sequence": 3, "owner": "Imani Rao", "due_date": "2026-09-06"}, "contains": {"action": ["release", "checklist"], "evidence": ["signed", "checklist"]}},
        {"kind": "all_valid_dates", "path": "/steps", "field": "due_date"},
        {"kind": "valid_date", "path": "/release_freeze_date"},
        {"kind": "exact", "path": "/release_freeze_date", "value": "2026-09-07"}
      ]
    }
  ],
  "long_context": {
    "targets": [8192, 32768, 131072],
    "needles": [
      {"position": "start", "code": "AURORA-1842"},
      {"position": "middle", "code": "CEDAR-7351"},
      {"position": "end", "code": "EMBER-9264"}
    ],
    "output_schema": {
      "type": "object",
      "required": ["codes"],
      "properties": {
        "codes": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  }
}
