{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prefer.local/schemas/eval-corpus-v1.json",
  "title": "PreFer synthetic evaluation corpus v1",
  "type": "object",
  "required": ["schema_version", "eval_version", "data_class", "cases", "long_context"],
  "properties": {
    "schema_version": {"const": "prefer.eval-corpus.v1"},
    "eval_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "data_class": {"const": "synthetic_non_private"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind", "source", "instruction", "output_schema", "semantic_rules"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "kind": {"enum": ["extraction", "synthesis"]},
          "source": {"type": "string", "minLength": 1},
          "instruction": {"type": "string", "minLength": 1},
          "output_schema": {"type": "object"},
          "semantic_rules": {"type": "array", "minItems": 1, "items": {"type": "object"}}
        },
        "additionalProperties": false
      }
    },
    "long_context": {
      "type": "object",
      "required": ["targets", "needles", "output_schema"],
      "properties": {
        "targets": {"type": "array", "items": {"type": "integer", "enum": [8192, 32768, 131072]}},
        "needles": {"type": "array", "minItems": 3, "items": {"type": "object"}},
        "output_schema": {"type": "object"}
      }
    }
  },
  "additionalProperties": false
}
