{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prefer.local/schemas/client-contract-v1.json",
  "title": "PreFer client contract v1",
  "type": "object",
  "required": [
    "schema_version",
    "contract_version",
    "scope",
    "endpoints",
    "structured_output",
    "tools",
    "errors_and_limits",
    "model_identity_rule",
    "models"
  ],
  "properties": {
    "schema_version": {"const": "prefer.client-contract.v1"},
    "contract_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "title": {"type": "string", "minLength": 1},
    "scope": {
      "type": "object",
      "required": ["promised", "not_promised"],
      "properties": {
        "promised": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "not_promised": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "endpoints": {
      "type": "object",
      "required": ["models", "chat_completions"],
      "properties": {
        "models": {"type": "object"},
        "chat_completions": {"type": "object"}
      }
    },
    "structured_output": {"type": "object"},
    "tools": {"type": "object"},
    "errors_and_limits": {"type": "object"},
    "model_identity_rule": {"type": "string", "minLength": 1},
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["canonical_id", "discovery_id", "aliases", "quantization", "presets"],
        "properties": {
          "canonical_id": {"type": "string", "minLength": 1},
          "discovery_id": {"type": "string", "minLength": 1},
          "aliases": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "quantization": {"type": "string", "minLength": 1},
          "presets": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "\\.ini$"}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
