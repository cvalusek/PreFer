{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://prefer.local/schemas/benchmark-result-v1.json",
  "title": "PreFer benchmark result v1",
  "type": "object",
  "required": ["schema_version", "run", "cells", "summary"],
  "properties": {
    "schema_version": {"const": "prefer.benchmark-result.v1"},
    "run": {
      "type": "object",
      "required": [
        "run_id",
        "started_at",
        "duration_ms",
        "source_revision",
        "source_dirty",
        "backend",
        "contract_version",
        "eval_version",
        "hardware",
        "preset",
        "models_max",
        "command"
      ],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "started_at": {"type": "string", "format": "date-time"},
        "duration_ms": {"type": "number", "minimum": 0},
        "source_revision": {"type": "string", "minLength": 7},
        "source_dirty": {"type": "boolean"},
        "backend": {
          "type": "object",
          "required": ["name", "base_image", "image_id", "revision", "comparison_lane"],
          "properties": {
            "name": {"const": "llama.cpp"},
            "base_image": {"type": "string", "minLength": 1},
            "image_id": {"type": ["string", "null"]},
            "revision": {"type": "string", "minLength": 1},
            "comparison_lane": {"type": "boolean"}
          },
          "additionalProperties": false
        },
        "contract_version": {"type": "string"},
        "eval_version": {"type": "string"},
        "hardware": {"type": "object"},
        "preset": {"type": "string", "pattern": "\\.ini$"},
        "models_max": {"type": "integer", "minimum": 0},
        "command": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "cleanup": {"type": "object"}
      }
    },
    "cells": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "status", "model", "measurements", "contract", "quality"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "kind": {
            "enum": [
              "cold_readiness",
              "models_discovery",
              "first_model_load",
              "warm_request",
              "idle_unload",
              "model_swap",
              "models_max",
              "concurrency",
              "streaming",
              "cancellation",
              "structured_output",
              "tools",
              "long_context",
              "environment"
            ]
          },
          "status": {"enum": ["passed", "failed", "error", "skipped", "unsupported"]},
          "model": {"type": ["object", "null"]},
          "context": {"type": ["object", "null"]},
          "measurements": {"type": "object"},
          "contract": {
            "type": "object",
            "required": ["pass", "checks"],
            "properties": {
              "pass": {"type": ["boolean", "null"]},
              "checks": {"type": "array", "items": {"type": "object"}}
            }
          },
          "quality": {
            "type": "object",
            "required": ["schema_valid", "semantic_evaluated", "semantic_anomalies"],
            "properties": {
              "schema_valid": {"type": ["boolean", "null"]},
              "semantic_evaluated": {"type": "boolean"},
              "semantic_anomalies": {"type": "array", "items": {"type": "object"}}
            }
          },
          "skip": {"type": "object"},
          "error": {"type": "object"},
          "evidence": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["cell_counts", "schema_contract_attempts", "schema_contract_pass_rate", "semantic_evaluations", "semantic_anomaly_rate"],
      "properties": {
        "cell_counts": {"type": "object"},
        "schema_contract_attempts": {"type": "integer", "minimum": 0},
        "schema_contract_pass_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "semantic_evaluations": {"type": "integer", "minimum": 0},
        "semantic_anomaly_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
      }
    }
  },
  "additionalProperties": false
}
